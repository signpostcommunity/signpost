function togglePickItem(el) { el.classList.toggle('checked'); }

// ===== SEND / SAVE ACTIONS =====
function sendRequest(type) {
  const labels = { goto:'Preferred Interpreters', extended:'Secondary Tier Interpreters', selected:'selected interpreters' };
  closeNewRequest();
  showDashPanel('requests', document.querySelector('.dash-nav-item[onclick*="requests"]'));
  goToDashboard();
  setTimeout(() => alert(`&#10003; Request sent to your ${labels[type] || 'interpreters'}. You'll be notified when they respond.`), 200);
}

function saveDraft() {
  closeNewRequest();
  showDashPanel('drafts', null);
  setTimeout(() => alert('Draft saved. You can find it in the Drafts section.'), 200);
}

// ===== FAV ACTIONS =====
function moveFav(btn, destination) {
  const item = btn.closest('.fav-item');
  const name = item.querySelector('.fav-name').textContent;
  item.style.transition = 'opacity 0.3s';
  item.style.opacity = '0';
  setTimeout(() => {
    item.remove();
    alert(`${name} moved to ${destination === 'goto' ? 'Preferred Interpreters' : 'Secondary Tier Interpreters'}.`);
  }, 300);
}

function removeFav(btn) {
  const item = btn.closest('.fav-item');
  const name = item.querySelector('.fav-name').textContent;
  if (confirm(`Remove ${name} from your favorites?`)) {
    item.style.transition = 'opacity 0.3s';
    item.style.opacity = '0';
    setTimeout(() => item.remove(), 300);
  }
}

