// ===== DIRECTORY FILTER =====
function filterDirectory() {
  const searchVal = (document.getElementById('dir-search')?.value || '').toLowerCase();
  const sidebar = document.getElementById('dir-sidebar');
  const selectedChips = sidebar ? Array.from(sidebar.querySelectorAll('.chip.selected')).map(c => c.textContent.trim().toLowerCase()) : [];

  const cards = document.querySelectorAll('#interpreters-grid .interp-card');
  let visibleCount = 0;

  cards.forEach((card, idx) => {
    const interp = interpreters[idx];
    if (!interp) return;

    // Search match
    const searchMatch = !searchVal ||
      interp.name.toLowerCase().includes(searchVal) ||
      interp.location.toLowerCase().includes(searchVal) ||
      interp.signLangs.some(l => l.toLowerCase().includes(searchVal)) ||
      interp.spokenLangs.some(l => l.toLowerCase().includes(searchVal)) ||
      interp.specs.some(s => s.toLowerCase().includes(searchVal));

    // Chip filter match — if no chips selected, show all
    let chipMatch = true;
    if (selectedChips.length > 0) {
      chipMatch = selectedChips.some(chip => {
        const chipClean = chip.replace(/[^a-z0-9\s]/gi,'').trim();
        return interp.name.toLowerCase().includes(chipClean) ||
          interp.signLangs.some(l => l.toLowerCase().includes(chipClean) || chipClean.includes(l.toLowerCase())) ||
          interp.spokenLangs.some(l => l.toLowerCase().includes(chipClean) || chipClean.includes(l.toLowerCase())) ||
          interp.specs.some(s => s.toLowerCase().includes(chipClean) || chipClean.includes(s.toLowerCase())) ||
          interp.certs.some(c => c.toLowerCase().includes(chipClean) || chipClean.includes(c.toLowerCase())) ||
          interp.regions.some(r => r.toLowerCase().includes(chipClean) || chipClean.includes(r.toLowerCase())) ||
          (chipClean === 'remote' && interp.available) ||
          (chipClean === 'on-site' && interp.available);
      });
    }

    const show = searchMatch && chipMatch;
    card.style.display = show ? '' : 'none';
    if (show) visibleCount++;
  });

  // Show empty state if nothing matches
  let emptyState = document.getElementById('dir-empty-state');
  if (!emptyState) {
    emptyState = document.createElement('div');
    emptyState.id = 'dir-empty-state';
    emptyState.style.cssText = 'grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--muted);';
    emptyState.innerHTML = '<div style="font-size:2rem;margin-bottom:12px;">🔍</div><div style="font-family:\'Syne\',sans-serif;font-weight:700;font-size:1rem;margin-bottom:8px;color:var(--text);">No interpreters found</div><div style="font-size:0.88rem;line-height:1.6;">Try adjusting your filters or search term.</div>';
    document.getElementById('interpreters-grid').appendChild(emptyState);
  }
  emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
}

