<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>signpost — find your interpreter, anywhere</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #000000;
    --surface: #0f1118;
    --surface2: #161923;
    --border: #1e2433;
    --accent: #00e5ff;
    --accent2: #7b61ff;
    --accent3: #ff4d6d;
    --text: #f0f2f8;
    --muted: #9ba3bc;
    --card-bg: #0d1220;
    --radius: 16px;
    --radius-sm: 10px;
  }

  html { scroll-behavior: smooth; overflow-x: hidden; font-size: 17px; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  .wordmark { font-family: 'Syne', sans-serif; font-weight: 800; color: var(--text); }
  .wordmark span { color: var(--accent); }

  /* ===== NOISE OVERLAY ===== */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.4;
  }

  /* ===== VIEWS ===== */
  .view { display: none; min-height: 100vh; }
  .view.active { display: block; }

  /* ===== NAV ===== */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 40px;
    background: rgba(7,9,16,0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    letter-spacing: -0.03em;
    cursor: pointer;
    font-size: 1.4rem;
    text-transform: lowercase;
  }

  .nav-logo span { color: var(--accent); }

  .nav-links { display: flex; gap: 8px; align-items: center; }

  .nav-btn {
    background: none; border: none; cursor: pointer;
    color: var(--muted); font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem; padding: 8px 16px; border-radius: 8px;
    transition: all 0.2s;
  }

  .nav-btn:hover { color: var(--text); background: var(--surface2); }
  .nav-btn.active { color: var(--text); }

  .btn-primary {
    background: var(--accent); color: #000;
    font-weight: 600; border-radius: 10px;
    padding: 9px 20px; border: none; cursor: pointer;
    font-family: 'DM Sans', sans-serif; font-size: 0.9rem;
    transition: all 0.2s;
  }

  .btn-primary:hover { background: #00cceb; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,229,255,0.25); }

  .btn-secondary {
    background: var(--surface2); color: var(--text);
    border: 1px solid var(--border);
    font-weight: 500; border-radius: 10px;
    padding: 9px 20px; border: none; cursor: pointer;
    font-family: 'DM Sans', sans-serif; font-size: 0.9rem;
    transition: all 0.2s;
  }

  .btn-secondary:hover { background: var(--border); }

  /* ===== HERO ===== */
  .hero {
    padding: 100px 64px 48px;
    max-width: 1200px; margin: 0 auto;
    position: relative;
  }

  .hero-glow { display: none; }

  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(0,229,255,0.08);
    border: 1px solid rgba(0,229,255,0.2);
    border-radius: 100px;
    padding: 6px 14px; font-size: 0.8rem;
    color: var(--accent); margin-bottom: 32px;
    font-weight: 500;
  }

  .hero-eyebrow::before {
    content: ''; width: 6px; height: 6px;
    border-radius: 50%; background: var(--accent);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; } 50% { opacity: 0.4; }
  }

  .hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 800; line-height: 1.05;
    letter-spacing: -0.04em;
    margin-bottom: 24px;
    max-width: 700px;
  }

  .hero h1 em {
    font-style: normal;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    font-size: 1rem; color: var(--muted);
    max-width: 520px; line-height: 1.7;
    margin-bottom: 44px;
  }

  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; max-width: 360px; }

  .btn-large {
    padding: 14px 32px; font-size: 1rem; border-radius: 12px;
  }

  .stats-row {
    display: flex; gap: 48px; margin-top: 80px;
    padding-top: 48px; border-top: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .stat { }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 2.4rem; font-weight: 800;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--text), var(--muted));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label { color: var(--muted); font-size: 0.85rem; margin-top: 2px; }

  /* ===== DIRECTORY VIEW ===== */
  .directory-layout {
    padding: 100px 0 0;
    display: grid;
    grid-template-columns: 300px 1fr;
    min-height: 100vh;
  }

  /* SIDEBAR */
  .sidebar {
    padding: 32px 28px;
    border-right: 1px solid var(--border);
    position: sticky; top: 72px;
    height: calc(100vh - 72px);
    overflow-y: auto;
  }

  .sidebar::-webkit-scrollbar { width: 4px; }
  .sidebar::-webkit-scrollbar-track { background: transparent; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .filter-section { margin-bottom: 28px; }

  .filter-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 12px;
  }

  .search-input {
    width: 100%; background: var(--surface2);
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 10px 14px; color: var(--text);
    font-family: 'DM Sans', sans-serif; font-size: 0.9rem;
    outline: none; transition: border-color 0.2s;
  }

  .search-input:focus { border-color: var(--accent); }
  .search-input::placeholder { color: var(--muted); }

  .chip-group { display: flex; flex-wrap: wrap; gap: 6px; }

  .chip {
    display: inline-flex; align-items: center; justify-content: center;
    height: 30px; box-sizing: border-box;
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 100px; padding: 0 12px;
    font-size: 0.78rem; cursor: pointer;
    color: var(--muted); transition: all 0.15s;
    white-space: nowrap; line-height: 1;
  }

  .chip:hover { border-color: var(--accent); color: var(--text); }
  .chip.selected { background: rgba(0,229,255,0.1); border-color: var(--accent); color: var(--accent); }

  .range-slider { width: 100%; accent-color: var(--accent); }

  .range-labels { display: flex; justify-content: space-between; font-size: 0.78rem; color: var(--muted); margin-top: 6px; }

  /* DIRECTORY MAIN */
  .directory-main { padding: 32px 48px; }

  .directory-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px; gap: 16px; flex-wrap: wrap;
  }

  .results-count { color: var(--muted); font-size: 0.9rem; }
  .results-count strong { color: var(--text); }

  .sort-select {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 8px 14px;
    color: var(--text); font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem; outline: none; cursor: pointer;
  }

  .interpreters-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  /* INTERPRETER CARD */
  .interp-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.25s;
    position: relative;
  }

  .interp-card:hover {
    border-color: rgba(0,229,255,0.3);
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.4);
  }

  .card-video-area {
    height: 180px; background: var(--surface2);
    position: relative; overflow: hidden;
  }

  .card-video-thumb {
    width: 100%; height: 100%; object-fit: cover;
  }

  .video-placeholder {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 10px; color: var(--muted);
  }

  .video-placeholder .play-icon {
    width: 48px; height: 48px;
    background: rgba(0,229,255,0.1);
    border: 1.5px solid rgba(0,229,255,0.3);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem;
    transition: all 0.2s;
  }

  .interp-card:hover .play-icon {
    background: rgba(0,229,255,0.2);
    border-color: var(--accent);
    color: var(--accent);
  }


  .card-body { padding: 18px; }

  .card-avatar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }

  .avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-weight: 700;
    font-size: 1rem; color: #fff; flex-shrink: 0;
  }

  .card-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700; font-size: 1rem;
  }

  .card-location { color: var(--muted); font-size: 0.8rem; }

  .card-langs {
    display: flex; flex-wrap: wrap; gap: 5px;
    margin-bottom: 12px;
  }

  .lang-tag {
    background: rgba(123,97,255,0.1);
    border: 1px solid rgba(123,97,255,0.25);
    color: #a891ff;
    border-radius: 6px; padding: 3px 8px; font-size: 0.72rem;
  }

  .lang-tag.spoken {
    background: rgba(255,77,109,0.08);
    border-color: rgba(255,77,109,0.2);
    color: #ff8099;
  }

  .lang-tag.tactile {
    background: rgba(52,211,153,0.1);
    border-color: rgba(52,211,153,0.28);
    color: #34d399;
  }

  .card-specializations {
    display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 14px;
  }

  .spec-tag {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 6px; padding: 3px 8px; font-size: 0.72rem;
    color: var(--muted);
  }

  .card-footer {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 12px; border-top: 1px solid var(--border);
  }

  .star-rating { color: #f5c518; font-size: 0.8rem; }
  .rating-count { color: var(--muted); font-size: 0.78rem; margin-left: 4px; }

  .cert-badge {
    background: rgba(0,229,255,0.08);
    border: 1px solid rgba(0,229,255,0.2);
    border-radius: 6px; padding: 3px 8px;
    font-size: 0.7rem; color: var(--accent);
  }

  /* ===== PROFILE VIEW ===== */
  .profile-view { padding-top: 80px; }

  .profile-hero {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 60px 0 0;
  }

  .profile-container { max-width: 1100px; margin: 0 auto; padding: 0 56px; }

  .back-btn {
    display: flex; align-items: center; gap: 6px;
    color: var(--muted); font-size: 0.85rem; cursor: pointer;
    margin-bottom: 32px; transition: color 0.2s;
    background: none; border: none; width: fit-content;
  }

  .back-btn:hover { color: var(--text); }

  .profile-top {
    display: grid; grid-template-columns: auto 1fr auto;
    gap: 32px; align-items: start;
    padding-bottom: 40px;
  }

  .profile-avatar {
    width: 100px; height: 100px; border-radius: 50%;
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-weight: 800;
    font-size: 2.4rem; color: #fff;
    border: 3px solid var(--border);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    flex-shrink: 0;
  }

  .profile-name {
    font-family: 'Syne', sans-serif;
    font-size: 2rem; font-weight: 800;
    letter-spacing: -0.03em; margin-bottom: 6px;
  }

  .profile-meta { color: var(--muted); font-size: 0.9rem; margin-bottom: 16px; }

  .profile-tags { display: flex; flex-wrap: wrap; gap: 6px; }

  .profile-actions { display: flex; flex-direction: column; gap: 10px; align-items: flex-end; }

  .profile-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid var(--border);
  }

  .tab-btn {
    background: none; border: none; cursor: pointer;
    color: var(--muted); font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem; padding: 16px 24px;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px; transition: all 0.2s;
  }

  .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

  .profile-body { max-width: 1100px; margin: 0 auto; padding: 48px 56px; }

  .profile-grid { display: grid; grid-template-columns: 1fr 340px; gap: 40px; }

  .section-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 700; font-size: 1.1rem;
    margin-bottom: 20px;
    display: flex; align-items: center; gap: 10px;
  }

  .section-heading::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }

  /* VIDEO PLAYER */
  .video-player {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 32px;
  }

  .video-screen {
    width: 100%; aspect-ratio: 16/9;
    background: #000;
    display: flex; align-items: center; justify-content: center;
    position: relative;
  }

  .big-play {
    width: 72px; height: 72px;
    background: rgba(0,229,255,0.15);
    border: 2px solid var(--accent);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem;
    cursor: pointer; transition: all 0.2s;
  }

  .big-play:hover { background: rgba(0,229,255,0.3); transform: scale(1.05); }

  .video-controls {
    padding: 14px 18px;
    display: flex; align-items: center; gap: 12px;
  }

  .progress-bar {
    flex: 1; height: 4px; background: var(--border);
    border-radius: 4px; overflow: hidden;
  }

  .progress-fill {
    width: 0%; height: 100%; background: var(--accent);
    transition: width 0.1s;
  }

  .video-time { color: var(--muted); font-size: 0.78rem; }

  /* CREDENTIALS SECTION */
  .cred-list { display: flex; flex-direction: column; gap: 12px; }

  .cred-item {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 16px 18px;
    display: flex; align-items: center; gap: 14px;
  }

  .cred-icon {
    width: 40px; height: 40px; border-radius: 10px;
    background: rgba(0,229,255,0.08);
    border: 1px solid rgba(0,229,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; flex-shrink: 0;
  }

  .cred-name { font-weight: 500; font-size: 0.9rem; }
  .cred-issuer { color: var(--muted); font-size: 0.78rem; }

  /* SIDEBAR CARD */
  .sidebar-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 20px;
  }

  .sidebar-card h3 {
    font-family: 'Syne', sans-serif;
    font-size: 0.85rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 16px;
  }

  .info-row {
    display: flex; justify-content: space-between;
    align-items: center; padding: 8px 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
  }

  .info-row:last-child { border-bottom: none; }
  .info-label { color: var(--muted); }
  .info-val { font-weight: 500; }

  .avail-chip {
    background: rgba(0,229,255,0.1);
    color: var(--accent); border: 1px solid rgba(0,229,255,0.25);
    border-radius: 6px; padding: 2px 8px; font-size: 0.75rem;
  }

  /* ===== SIGNUP FORM VIEW ===== */
  .signup-view { padding: 100px 40px 60px; }

  .form-container { max-width: 1000px; margin: 0 auto; }

  .form-header { margin-bottom: 48px; }

  .form-header h1 {
    font-family: 'Syne', sans-serif;
    font-size: 2.4rem; font-weight: 800;
    letter-spacing: -0.04em; margin-bottom: 8px;
  }

  .form-header p { color: var(--muted); }

  .form-steps {
    display: flex; gap: 0; margin-bottom: 48px;
    background: var(--surface2); border-radius: 12px;
    padding: 6px; border: 1px solid var(--border);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    white-space: nowrap;
  }
  .form-steps::-webkit-scrollbar { display: none; }

  .form-step {
    flex: 1; flex-shrink: 0; text-align: center; padding: 10px;
    border-radius: 8px; font-size: 0.82rem;
    color: var(--muted); cursor: pointer; transition: all 0.2s;
    font-weight: 500; min-width: 100px;
  }

  .form-step.active {
    background: var(--surface); color: var(--text);
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  .form-step.done { color: var(--accent); cursor: pointer; }
  .form-step.done:hover { color: var(--text); background: var(--surface); }

  .form-section { margin-bottom: 36px; }

  .form-section-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 20px;
    display: flex; align-items: center; gap: 8px;
  }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  .form-row.full { grid-template-columns: 1fr; }
  .form-row.three { grid-template-columns: 1fr 1fr 1fr; }
  @media (max-width: 640px) {
    .form-row, .form-row.three { grid-template-columns: 1fr; }
  }

  .form-field { display: flex; flex-direction: column; gap: 6px; }

  label {
    font-size: 0.82rem; color: var(--muted); font-weight: 500;
  }

  input[type="text"],
  input[type="email"],
  input[type="url"],
  input[type="tel"],
  select,
  textarea {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 11px 14px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }

  input:focus, select:focus, textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(0,229,255,0.07);
  }

  textarea { resize: vertical; min-height: 100px; }

  select option { background: var(--surface); }

  /* Video Upload */
  .upload-area {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 48px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
  }

  .upload-area:hover {
    border-color: rgba(0,229,255,0.4);
    background: rgba(0,229,255,0.02);
  }

  .upload-icon { font-size: 2.5rem; margin-bottom: 12px; }
  .upload-text { color: var(--muted); font-size: 0.88rem; }
  .upload-text strong { color: var(--accent); }

  /* Cert items */
  .cert-builder { display: flex; flex-direction: column; gap: 10px; }

  .cert-item-form {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 20px 24px;
    width: 100%; box-sizing: border-box;
  }

  .remove-btn {
    background: rgba(255,77,109,0.1); border: 1px solid rgba(255,77,109,0.2);
    color: var(--accent3); border-radius: 8px;
    padding: 8px 10px; cursor: pointer;
    font-size: 0.9rem; transition: all 0.2s;
  }

  .remove-btn:hover { background: rgba(255,77,109,0.2); }

  .add-btn {
    background: none; border: 1px dashed var(--border);
    color: var(--muted); border-radius: var(--radius-sm);
    padding: 10px; width: 100%; cursor: pointer;
    font-family: 'DM Sans', sans-serif; font-size: 0.85rem;
    transition: all 0.2s;
  }

  .add-btn:hover { border-color: var(--accent); color: var(--accent); }

  .form-nav {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 32px; border-top: 1px solid var(--border);
    margin-top: 40px;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    nav { padding: 16px 20px; }
    .hero { padding: 120px 24px 60px; }
    .directory-layout { grid-template-columns: 1fr; }
    .sidebar { display: none; }
    .directory-main { padding: 24px 24px; }
    .profile-top { grid-template-columns: 1fr; }
    .profile-actions { align-items: flex-start; flex-direction: row; }
    .profile-grid { grid-template-columns: 1fr; }
    .profile-body { padding: 32px 24px; }
    .profile-container { padding: 0 24px; }
    .form-row { grid-template-columns: 1fr; }
    .signup-view { padding: 100px 24px 60px; }
    .dash-main { padding: 32px 24px; }
    .stats-row { gap: 24px; }
    .about-hero-outer { padding: 60px 24px 40px !important; }
    .about-content-outer { padding: 40px 24px !important; }
  }

  /* ===== ANIMATIONS ===== */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .view.active .hero h1,
  .view.active .hero p,
  .view.active .hero-ctas {
    animation: fadeUp 0.6s ease both;
  }

  .view.active .hero p { animation-delay: 0.1s; }
  .view.active .hero-ctas { animation-delay: 0.2s; }

  /* Floating gradient shapes */
  .shape {
    position: absolute; border-radius: 50%;
    filter: blur(80px); pointer-events: none;
  }

  .shape-1 {
    width: 400px; height: 400px;
    background: rgba(0,229,255,0.04);
    top: -100px; right: -100px;
  }

  .shape-2 {
    width: 300px; height: 300px;
    background: rgba(123,97,255,0.05);
    bottom: 0; left: 100px;
  }

  .region-option {
    display: flex; align-items: center; gap: 10px;
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 12px 14px;
    cursor: pointer; transition: all 0.15s; user-select: none;
    font-size: 0.85rem; color: var(--muted);
  }

  .region-option:hover { border-color: rgba(0,229,255,0.3); color: var(--text); }

  .region-option.selected {
    background: rgba(0,229,255,0.06);
    border-color: rgba(0,229,255,0.35);
    color: var(--text);
  }

  .region-icon-dot {
    width: 10px; height: 10px; border-radius: 50%;
    flex-shrink: 0; opacity: 0.7;
  }

  .region-option.selected .region-icon-dot { opacity: 1; }

  .region-name { flex: 1; font-weight: 500; }

  .region-check {
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--border); border: 1.5px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.6rem; color: transparent; flex-shrink: 0;
    transition: all 0.15s;
  }

  .region-option.selected .region-check {
    background: var(--accent); border-color: var(--accent);
    color: #000;
  }

  /* Region badges on profile */
  .region-badge {
    display: inline-flex; align-items: center; gap: 5px;
    border-radius: 7px; padding: 4px 9px;
    font-size: 0.75rem; font-weight: 600;
    letter-spacing: 0.01em;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--muted);
  }

  .region-badge.active {
    background: rgba(from var(--rc, #00e5ff) r g b / 0.1);
    border-color: rgba(from var(--rc, #00e5ff) r g b / 0.35);
    color: var(--rc, var(--accent));
  }

  .region-badge.inactive {
    opacity: 0.4;
  }

  /* Fallback for browsers without relative color syntax */
  .region-badge[style*="--rc:#00e5ff"] { background: rgba(0,229,255,0.1); border-color: rgba(0,229,255,0.35); color: #00e5ff; }
  .region-badge[style*="--rc:#60a5fa"] { background: rgba(96,165,250,0.1); border-color: rgba(96,165,250,0.35); color: #60a5fa; }
  .region-badge[style*="--rc:#f97316"] { background: rgba(249,115,22,0.1); border-color: rgba(249,115,22,0.35); color: #f97316; }
  .region-badge[style*="--rc:#a78bfa"] { background: rgba(167,139,250,0.1); border-color: rgba(167,139,250,0.35); color: #a78bfa; }
  .region-badge[style*="--rc:#fb923c"] { background: rgba(251,146,60,0.1); border-color: rgba(251,146,60,0.35); color: #fb923c; }
  .region-badge[style*="--rc:#34d399"] { background: rgba(52,211,153,0.1); border-color: rgba(52,211,153,0.35); color: #34d399; }
  .region-badge[style*="--rc:#f472b6"] { background: rgba(244,114,182,0.1); border-color: rgba(244,114,182,0.35); color: #f472b6; }
  .region-badge[style*="--rc:#facc15"] { background: rgba(250,204,21,0.1); border-color: rgba(250,204,21,0.35); color: #facc15; }
  /* ===== LANGUAGE PICKER ===== */
  .lang-picker { }

  .lang-picker-top-label {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--muted); margin-bottom: 8px;
    font-family: 'Syne', sans-serif;
  }

  .lang-picker-continents { margin-top: 10px; }

  .continent-accordions-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .continent-accordion {
    flex: 1 1 calc(50% - 3px);
    min-width: 140px;
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .continent-accordion.open {
    flex: 1 1 100%;
  }

  .continent-accordion-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 9px 14px; cursor: pointer; background: var(--surface2);
    font-size: 0.82rem; font-weight: 500; color: var(--muted);
    transition: color 0.15s, background 0.15s; user-select: none;
  }

  .continent-accordion-header:hover { color: var(--text); background: var(--border); }

  .continent-accordion-chevron {
    font-size: 0.7rem; transition: transform 0.2s;
  }

  .continent-accordion.open .continent-accordion-chevron { transform: rotate(180deg); }

  .continent-accordion-body {
    display: none; padding: 10px 12px; background: var(--card-bg);
    border-top: 1px solid var(--border);
  }

  .continent-accordion.open .continent-accordion-body { display: block; }

  .lang-picker-other-field {
    margin-top: 10px;
    display: none;
  }

  .filter-toggle {
    display: none;
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 8px 14px;
    color: var(--text); font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem; cursor: pointer;
  }

  @media (max-width: 900px) {
    .filter-toggle { display: flex; align-items: center; gap: 6px; }
  }

  /* ===== REQUESTER STYLES ===== */
  .role-selector {
    display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;
  }

  .role-card {
    background: var(--surface2);
    border: 2px solid var(--border);
    border-radius: var(--radius);
    padding: 28px 22px;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
    user-select: none;
  }

  .role-card:hover { border-color: rgba(0,229,255,0.4); }

  .role-card.selected {
    background: rgba(0,229,255,0.06);
    border-color: var(--accent);
  }

  .role-card-icon { font-size: 2.2rem; margin-bottom: 12px; }

  .role-card-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700; font-size: 1rem;
    margin-bottom: 6px;
  }

  .role-card-desc { color: var(--muted); font-size: 0.8rem; line-height: 1.5; }

  /* DASHBOARD LAYOUT */
  .dashboard-layout {
    padding-top: 72px;
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: 100vh;
  }

  .dash-sidebar {
    background: var(--surface);
    border-right: 1px solid var(--border);
    padding: 32px 0;
    position: sticky; top: 72px;
    height: calc(100vh - 72px);
    overflow-y: auto;
  }

  .dash-sidebar-header {
    padding: 0 24px 24px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 8px;
  }

  .dash-user-info { display: flex; align-items: center; gap: 12px; }

  .dash-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-weight: 700;
    font-size: 0.95rem; color: #fff; flex-shrink: 0;
  }

  .dash-user-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700; font-size: 0.9rem;
    margin-bottom: 2px;
  }

  .dash-user-role {
    font-size: 0.73rem; color: var(--muted);
  }

  .dash-nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 24px; cursor: pointer;
    font-size: 0.88rem; color: var(--muted);
    border-left: 3px solid transparent;
    transition: all 0.15s; border: none; background: none;
    font-family: 'DM Sans', sans-serif;
    width: 100%; text-align: left;
  }

  .dash-nav-item:hover { color: var(--text); background: rgba(255,255,255,0.03); }

  .dash-nav-item.active {
    color: var(--accent);
    background: rgba(0,229,255,0.06);
    border-left-color: var(--accent);
  }

  .dash-nav-icon { font-size: 1rem; width: 20px; text-align: center; }

  .dash-nav-section {
    font-family: 'Syne', sans-serif;
    font-size: 0.65rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted); padding: 16px 24px 6px;
  }

  .dash-badge {
    margin-left: auto;
    background: var(--accent); color: #000;
    border-radius: 100px; font-size: 0.65rem;
    font-weight: 700; padding: 2px 7px;
    font-family: 'Syne', sans-serif;
  }

  /* DASHBOARD MAIN */
  .dash-main { padding: 48px 56px; overflow-y: auto; }

  .dash-panel { display: none; }
  .dash-panel.active { display: block; }

  .dash-page-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.6rem; font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 6px;
  }

  .dash-page-subtitle { color: var(--muted); font-size: 0.88rem; margin-bottom: 32px; }

  /* REQUEST CARDS */
  .request-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 16px;
    transition: border-color 0.2s;
  }

  .request-card:hover { border-color: rgba(0,229,255,0.2); }

  .request-card-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 14px; gap: 16px; flex-wrap: wrap;
  }

  .request-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700; font-size: 1rem;
  }

  .request-status {
    border-radius: 100px; padding: 4px 12px;
    font-size: 0.72rem; font-weight: 700;
    font-family: 'Syne', sans-serif;
    letter-spacing: 0.04em; text-transform: uppercase;
    white-space: nowrap;
  }

  .status-draft { background: rgba(107,117,146,0.15); color: var(--muted); border: 1px solid var(--border); }
  .status-sent { background: rgba(123,97,255,0.12); color: #a891ff; border: 1px solid rgba(123,97,255,0.3); }
  .status-confirmed { background: rgba(0,229,255,0.1); color: var(--accent); border: 1px solid rgba(0,229,255,0.3); }

  /* Availability grid cells */
  .avail-cell {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 4px; font-size: 0.75rem;
    color: var(--muted); cursor: pointer; transition: all 0.18s; user-select: none;
  }
  .avail-cell:hover { border-color: rgba(0,229,255,0.3); color: var(--text); }
  .avail-cell.active {
    background: rgba(0,229,255,0.12); border-color: rgba(0,229,255,0.3);
    color: var(--accent);
  }

  /* Toast notification */
  .sp-toast {
    position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%) translateY(20px);
    background: var(--surface2); border: 1px solid var(--border);
    color: var(--text); padding: 12px 24px; border-radius: 10px;
    font-size: 0.88rem; z-index: 9999; opacity: 0;
    transition: all 0.3s; pointer-events: none; white-space: nowrap;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .sp-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  .sp-toast.success { border-color: rgba(0,229,255,0.4); color: var(--accent); }
  .sp-toast.warning { border-color: rgba(250,204,21,0.4); color: #facc15; }

  /* Detail modal */
  .detail-modal-overlay {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7);
    z-index: 500; align-items: center; justify-content: center;
    backdrop-filter: blur(4px);
  }
  .detail-modal-overlay.open { display: flex; }
  .detail-modal {
    background: var(--card-bg); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 32px; max-width: 480px; width: 90%;
  }
  .detail-modal h3 { font-family: 'Syne', sans-serif; font-weight: 700; margin-bottom: 12px; }
  .detail-modal p { color: var(--muted); line-height: 1.7; font-size: 0.9rem; }
  .detail-modal .meta-row { color: var(--muted); font-size: 0.85rem; margin-bottom: 8px; }
  .detail-modal .status-note { color: var(--text); margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border); font-size: 0.88rem; }

  /* Decline reason buttons */
  .decline-reason-btn {
    width: 100%; text-align: left; padding: 12px 16px;
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 10px; color: var(--muted); font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem; cursor: pointer; transition: all 0.15s;
  }
  .decline-reason-btn:hover { border-color: rgba(255,77,109,0.35); color: var(--text); }
  .decline-reason-btn.selected {
    background: rgba(255,77,109,0.08); border-color: rgba(255,77,109,0.5);
    color: #ff6b87; font-weight: 500;
  }
  #decline-confirm-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* Calendar add dropdown */
  .cal-dropdown-wrap { position: relative; display: inline-block; }
  .cal-dropdown {
    display: none; position: absolute; bottom: 100%; left: 0; margin-bottom: 6px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-sm); min-width: 200px; z-index: 50;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4); overflow: hidden;
  }
  .cal-dropdown.open { display: block; }
  .cal-dropdown a {
    display: flex; align-items: center; gap: 10px;
    padding: 11px 16px; font-size: 0.83rem; color: var(--text);
    text-decoration: none; transition: background 0.15s;
    border-bottom: 1px solid var(--border);
  }
  .cal-dropdown a:last-child { border-bottom: none; }
  .cal-dropdown a:hover { background: var(--surface2); }
  .cal-dropdown a svg { flex-shrink: 0; }
  .status-pending { background: rgba(250,204,21,0.1); color: #facc15; border: 1px solid rgba(250,204,21,0.25); }

  .request-meta {
    display: flex; flex-wrap: wrap; gap: 16px;
    font-size: 0.82rem; color: var(--muted);
    margin-bottom: 12px;
  }

  .request-meta span { display: flex; align-items: center; gap: 5px; }

  .request-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }

  /* FAVORITES */
  .favorites-tier {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 24px;
    overflow: hidden;
  }

  .favorites-tier-header {
    padding: 18px 24px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }

  .tier-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700; font-size: 0.95rem;
    display: flex; align-items: center; gap: 10px;
  }

  .tier-badge {
    font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    padding: 3px 9px; border-radius: 100px;
  }

  .tier-primary { background: rgba(245,197,24,0.12); color: #f5c518; border: 1px solid rgba(245,197,24,0.25); }
  .tier-extended { background: rgba(123,97,255,0.12); color: #a891ff; border: 1px solid rgba(123,97,255,0.25); }

  .favorites-list { padding: 16px 24px; display: flex; flex-direction: column; gap: 12px; }

  .fav-item {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 16px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: all 0.15s;
  }

  .fav-item:hover { border-color: rgba(0,229,255,0.2); }

  .fav-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-weight: 700;
    font-size: 0.85rem; color: #fff; flex-shrink: 0;
  }

  .fav-info { flex: 1; min-width: 0; }
  .fav-name { font-weight: 600; font-size: 0.9rem; margin-bottom: 2px; }
  .fav-details { color: var(--muted); font-size: 0.78rem; }

  .fav-actions { display: flex; gap: 6px; }

  .fav-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted); border-radius: 8px;
    padding: 6px 10px; cursor: pointer;
    font-size: 0.78rem; transition: all 0.15s;
  }

  .fav-btn:hover { border-color: var(--accent); color: var(--accent); }

  .empty-state {
    text-align: center; padding: 40px 24px;
    color: var(--muted); font-size: 0.88rem;
  }

  .empty-state-icon { font-size: 2rem; margin-bottom: 10px; opacity: 0.5; }

  /* NEW REQUEST FORM */
  .request-form-overlay {
    display: none;
    position: fixed; inset: 0; z-index: 200;
    background: rgba(7,9,16,0.8); backdrop-filter: blur(12px);
    align-items: flex-start; justify-content: center;
    padding: 80px 20px 20px;
    overflow-y: auto;
  }

  .request-form-overlay.open { display: flex; }

  .request-form-modal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    width: 100%; max-width: 720px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.5);
  }

  .modal-header {
    padding: 28px 32px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }

  .modal-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800; font-size: 1.2rem;
    letter-spacing: -0.02em;
  }

  .modal-close {
    background: var(--surface2); border: 1px solid var(--border);
    color: var(--muted); border-radius: 8px;
    padding: 6px 10px; cursor: pointer; font-size: 1rem;
    transition: all 0.15s;
  }

  .modal-close:hover { color: var(--text); }

  .modal-body { padding: 32px; }

  .modal-footer {
    padding: 20px 32px;
    border-top: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px;
  }

  .send-options { display: flex; gap: 8px; flex-wrap: wrap; }

  .send-btn-primary {
    background: var(--accent); color: #000;
    font-weight: 700; border-radius: 10px;
    padding: 10px 20px; border: none; cursor: pointer;
    font-family: 'DM Sans', sans-serif; font-size: 0.88rem;
    transition: all 0.2s;
  }

  .send-btn-primary:hover { background: #00cceb; transform: translateY(-1px); }

  .send-btn-tier {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text);
    font-weight: 600; border-radius: 10px;
    padding: 10px 18px; border-radius: 10px; cursor: pointer;
    font-family: 'DM Sans', sans-serif; font-size: 0.85rem;
    transition: all 0.2s;
  }

  .send-btn-tier:hover { border-color: rgba(0,229,255,0.3); }

  .send-btn-draft {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted); border-radius: 10px;
    padding: 10px 18px; cursor: pointer;
    font-family: 'DM Sans', sans-serif; font-size: 0.85rem;
    transition: all 0.2s;
  }

  .send-btn-draft:hover { color: var(--text); border-color: var(--muted); }

  /* Recipient picker */
  .recipient-picker {
    display: none; padding: 16px;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: var(--radius-sm); margin-top: 12px;
  }

  .recipient-picker.open { display: block; }

  .interp-pick-item {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 12px; border-radius: 8px;
    cursor: pointer; transition: background 0.1s;
    font-size: 0.85rem;
  }

  .interp-pick-item:hover { background: var(--surface2); }

  .interp-pick-check {
    width: 18px; height: 18px; border-radius: 4px;
    border: 1.5px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem; transition: all 0.15s;
    flex-shrink: 0;
  }

  .interp-pick-item.checked .interp-pick-check {
    background: var(--accent); border-color: var(--accent); color: #000;
  }

  /* Recurrence toggle */
  .recurrence-row {
    display: flex; gap: 8px; flex-wrap: wrap;
  }

  .recur-btn {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 8px; padding: 8px 14px; cursor: pointer;
    font-size: 0.8rem; color: var(--muted); transition: all 0.15s;
  }

  .recur-btn.active {
    background: rgba(0,229,255,0.1); border-color: rgba(0,229,255,0.35);
    color: var(--accent);
  }

