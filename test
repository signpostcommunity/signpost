// ============ VIDEO PLAY SIM ============
function simulatePlay(btn) {
  btn.textContent = '⏸';
  let w = 0;
  const fill = document.getElementById('progress-fill');
  if (!fill) return;
  const iv = setInterval(() => {
    w += 0.5;
    fill.style.width = w + '%';
    if (w >= 100) { clearInterval(iv); btn.textContent = '&#9654;'; fill.style.width = '0%'; }
  }, 80);
}

