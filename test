<script>
// ===== COLLAPSIBLE RATE CARDS =====
function toggleRateCard(bodyId, chevronId) {
  const body = document.getElementById(bodyId);
  const chevron = document.getElementById(chevronId);
  if (!body) return;
  const isOpen = body.style.display !== 'none';
  body.style.display = isOpen ? 'none' : 'block';
  if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
}

function toggleSignupRateCard(cardId, e) {
  const card = document.getElementById(cardId);
  if (!card) return;
  const body = card.querySelector('.rate-profile-body');
  const isCollapsed = card.classList.contains('collapsed');
  card.classList.toggle('collapsed', !isCollapsed);
  if (body) body.style.display = isCollapsed ? 'block' : 'none';
}

// ===== DASHBOARD PANEL =====
function showDashPanel(name, btn) {
  document.querySelectorAll('.dash-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.dash-nav-item').forEach(b => b.classList.remove('active'));
  const panel = document.getElementById('panel-' + name);
  if (panel) panel.classList.add('active');
  if (btn) btn.classList.add('active');
  if (name === 'interp-availability') renderAvailDays();
}

// ===== TABS =====
function switchTab(btn, name) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('[id^="tab-"]').forEach(t => t.style.display='none');
  const tab = document.getElementById('tab-' + name);
  if (tab) tab.style.display = (name === 'overview') ? 'grid' : 'block';
}

function toggleChip(el) { el.classList.toggle('selected'); }

// ===== REGION OPTIONS =====
function toggleRegion(el) { el.classList.toggle('selected'); }

// ===== ROLE SELECTION (requester signup) =====
function selectRole(el, role) {
  document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  const orgFields = ['org-name-field','org-type-field'];
  orgFields.forEach(id => document.getElementById(id).style.display = 'none');
  if (role === 'organization') {
    document.getElementById('org-name-field').style.display = 'grid';
    document.getElementById('org-type-field').style.display = 'grid';
  }
}

// ===== REQUESTER SIGNUP STEPS =====
function reqNextStep(step) {
  for (let i = 1; i <= 5; i++) {
    const el = document.getElementById('req-step-' + i);
    if (el) el.style.display = (i === step) ? 'block' : 'none';
  }
  document.querySelectorAll('#req-steps .form-step').forEach((s, idx) => {
    s.classList.remove('active','done');
    if (idx + 1 === step) s.classList.add('active');
    else if (idx + 1 < step) s.classList.add('done');
  });
}

// Allow clicking on completed (done) steps to go back
function reqGoToStep(step) {
  const steps = document.querySelectorAll('#req-steps .form-step');
  // Determine current highest reached step
  let maxReached = 1;
  steps.forEach((s, idx) => {
    if (s.classList.contains('active') || s.classList.contains('done')) {
      maxReached = Math.max(maxReached, idx + 1);
    }
  });
  // Only allow navigating to steps already reached
  if (step <= maxReached) {
    reqNextStep(step);
  }
}

// ===== SKIP FIRST REQUEST =====
function toggleSkipRequest() {
  const cb = document.getElementById('skip-request-cb');
  const fields = document.getElementById('first-request-fields');
  const btn = document.getElementById('req-step3-btn');
  if (cb.checked) {
    fields.style.opacity = '0.35';
    fields.style.pointerEvents = 'none';
    btn.textContent = 'Skip for now →';
  } else {
    fields.style.opacity = '1';
    fields.style.pointerEvents = '';
    btn.textContent = 'Continue →';
  }
}

