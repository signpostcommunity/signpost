  btn.closest('.recurrence-row').querySelectorAll('.recur-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// ===== SEND TARGET TOGGLE =====
function toggleSendTarget(btn, target) {
  document.querySelectorAll('#send-goto-toggle,#send-extended-toggle,#send-select-toggle').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const picker = document.getElementById('recipient-picker');
  picker.classList.toggle('open', target === 'select');
}

