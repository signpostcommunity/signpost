}

// ===== MINI CALENDAR =====
let calCurrentDate = new Date(2026, 1, 1);
const bookedDates = ['2026-02-22','2026-02-25','2026-03-04','2026-03-05','2026-03-12'];

function toggleCalendarView() {
  const cal = document.getElementById('booking-calendar');
  const btn = document.getElementById('cal-view-btn');
  if (!cal) return;
  const showing = cal.style.display !== 'none';
  cal.style.display = showing ? 'none' : 'block';
  if (btn) { btn.style.borderColor = showing ? '' : 'rgba(0,229,255,0.5)'; btn.style.color = showing ? '' : 'var(--accent)'; }
  if (!showing) renderCalendar();
}

function changeCalMonth(dir) {
  calCurrentDate = new Date(calCurrentDate.getFullYear(), calCurrentDate.getMonth() + dir, 1);
  renderCalendar();
}

function renderCalendar() {
  const label = document.getElementById('cal-month-label');
  const grid = document.getElementById('cal-days-grid');
  if (!label || !grid) return;
  const year = calCurrentDate.getFullYear();
  const month = calCurrentDate.getMonth();
  label.textContent = calCurrentDate.toLocaleString('default', { month: 'long', year: 'numeric' });
  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const startOffset = firstDay === 0 ? 6 : firstDay - 1;
  let html = '';
  for (let i = 0; i < startOffset; i++) html += '<div></div>';
  for (let d = 1; d <= daysInMonth; d++) {
    const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const hasBooking = bookedDates.includes(dateStr);
    const isToday = new Date().toISOString().slice(0,10) === dateStr;
    html += `<div onclick="showCalDay('${dateStr}',${hasBooking})" style="padding:5px 2px;font-size:0.78rem;border-radius:6px;cursor:pointer;background:${hasBooking?'rgba(0,229,255,0.12)':'transparent'};color:${hasBooking?'var(--accent)':isToday?'var(--text)':'var(--muted)'};border:1px solid ${isToday?'var(--accent)':'transparent'};font-weight:${hasBooking||isToday?'700':'400'};text-align:center;">${d}${hasBooking?'<div style="width:4px;height:4px;border-radius:50%;background:var(--accent);margin:2px auto 0;"></div>':''}</div>`;
  }
  grid.innerHTML = html;
  document.getElementById('cal-day-detail').style.display = 'none';
}

function showCalDay(dateStr, hasBooking) {
  const detail = document.getElementById('cal-day-detail');
  if (!detail) return;
  const d = new Date(dateStr + 'T12:00');
  const lbl = d.toLocaleDateString('default', { weekday:'long', month:'long', day:'numeric' });
  detail.style.display = 'block';
  detail.innerHTML = hasBooking
    ? `<strong style="color:var(--text);">${lbl}</strong> — You have a confirmed booking. <a href="#" style="color:var(--accent);text-decoration:none;" onclick="event.preventDefault();toggleCalendarView();document.getElementById('booking-search').value='${dateStr.slice(5)}';filterBookings()">Show booking →</a>`
    : `<strong style="color:var(--text);">${lbl}</strong> — No bookings.`;
}

// ===== MOVEFAV: actually move card to destination list =====
// Override the original moveFav to actually move the card
(function() {
  const _orig = window.moveFav;
  window.moveFav = function(btn, destination) {
    const item = btn.closest('.fav-item');
    const name = item.querySelector('.fav-name').textContent;
    const targetPanelId = destination === 'goto' ? 'panel-go-to' : 'panel-extended';
    const targetListId = destination === 'goto' ? 'goto-fav-list' : 'extended-fav-list';

    item.style.transition = 'opacity 0.3s';
    item.style.opacity = '0';
    setTimeout(() => {
      item.remove();
      // Find or create target list
      const targetPanel = document.getElementById(targetPanelId);
      let targetList = document.getElementById(targetListId);
      if (targetPanel && !targetList) {
        targetList = targetPanel.querySelector('.fav-list') || targetPanel;
      }
      if (targetList) {
        // Rebuild item with correct move button
        const newItem = document.createElement('div');
        newItem.className = 'fav-item';
        const avatar = item.querySelector ? '' : '';
        newItem.innerHTML = item.innerHTML;
        // Update move button direction
        const moveBtn = newItem.querySelector('.fav-btn[onclick*="moveFav"]');
        if (moveBtn) {
          if (destination === 'goto') {
            moveBtn.setAttribute('onclick', "moveFav(this,'extended')");
            moveBtn.title = 'Move to Secondary Tier Interpreters';
            moveBtn.textContent = '↓';
          } else {
            moveBtn.setAttribute('onclick', "moveFav(this,'goto')");
            moveBtn.title = 'Move to Preferred';
            moveBtn.textContent = '↑';
          }
        }
        targetList.appendChild(newItem);
      }
      const destName = destination === 'goto' ? 'Preferred Interpreters' : 'Secondary Tier Interpreters';
      showToast(name + ' moved to ' + destName + '.', 'success');
    }, 300);
  };
})();

// ===== OVERRIDE SENDREQUST to use toast instead of alert =====
(function() {
  window.sendRequest = function(type) {
    const labels = { goto:'Preferred Interpreters', extended:'Secondary Tier Interpreters', selected:'selected interpreters' };
    closeNewRequest();
    const navBtn = document.querySelector('.dash-nav-item[onclick*="requests"]');
    showDashPanel('requests', navBtn);
    showToast('✓ Request sent to your ' + (labels[type] || 'interpreters') + '. You\'ll be notified when they respond.', 'success');
  };

  window.saveDraft = function() {
    closeNewRequest();
    const navBtn = document.querySelector('.dash-nav-item[onclick*="drafts"]');
    showDashPanel('drafts', navBtn);
    showToast('Draft saved. Find it in the Drafts section.', 'success');
  };

  window.removeFav = function(btn) {
    const item = btn.closest('.fav-item');
    const name = item.querySelector('.fav-name').textContent;
    const actions = item.querySelector('.fav-actions') || item;
    // Show inline confirm on the button itself
    const originalText = btn.textContent;
    const originalStyle = btn.getAttribute('style') || '';
    btn.textContent = 'Sure?';
    btn.style.color = 'var(--accent3)';
    btn.style.borderColor = 'rgba(255,77,109,0.5)';
    btn.onclick = function() {
      item.style.transition = 'opacity 0.3s';
      item.style.opacity = '0';
      setTimeout(() => { item.remove(); showToast(name + ' removed from favorites.'); }, 300);
    };
    // Add a cancel option
    const cancelBtn = document.createElement('button');
    cancelBtn.className = 'fav-btn';
    cancelBtn.textContent = 'No';
    cancelBtn.style.cssText = 'font-size:0.78rem;padding:4px 10px;';
    cancelBtn.onclick = function() {
      btn.textContent = originalText;
      btn.setAttribute('style', originalStyle);
      btn.onclick = function() { window.removeFav(btn); };
      cancelBtn.remove();
    };
    btn.insertAdjacentElement('afterend', cancelBtn);
  };
})();

// ===== DASH RATE PROFILES =====
function toggleDashRateCard(id, event) {
  const card = document.getElementById(id);
  if (!card) return;
  const body = card.querySelector('.rate-profile-body');
  const chevron = card.querySelector('.rate-profile-chevron');
  const isCollapsed = card.classList.contains('collapsed');
  card.classList.toggle('collapsed', !isCollapsed);
  if (body) body.style.display = isCollapsed ? '' : 'none';
  if (chevron) chevron.style.transform = isCollapsed ? 'rotate(180deg)' : '';
}

function saveDashRate(id) {
  showToast('✓ Rate profile saved successfully.', 'success');
}

function removeDashRateProfile(id) {
  const card = document.getElementById(id);
  if (!card) return;
  const name = card.querySelector('.rate-profile-name')?.textContent || 'Rate profile';
  card.style.transition = 'opacity 0.3s, max-height 0.3s';
  card.style.opacity = '0';
  setTimeout(() => { card.remove(); showToast(name + ' removed.', 'success'); }, 300);
}

