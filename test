function fmtICS(dt) { return dt.replace(/[-:]/g,'') + '00Z'; }
function addToGcal(e, title, start, end, loc) {
  e.preventDefault();
  const s = start.replace(/[-:]/g,'') + '00Z';
  const en = end.replace(/[-:]/g,'') + '00Z';
  window.open(`https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(title)}&dates=${s}/${en}&location=${encodeURIComponent(loc)}&details=${encodeURIComponent('Booked via signpost')}`, '_blank');
}
function addToOutlook(e, title, start, end, loc) {
  e.preventDefault();
  window.open(`https://outlook.live.com/calendar/0/deeplink/compose?subject=${encodeURIComponent(title)}&startdt=${start}&enddt=${end}&location=${encodeURIComponent(loc)}&body=${encodeURIComponent('Booked via signpost')}`, '_blank');
}
function addToIcal(e, title, start, end, loc) {
  e.preventDefault();
  const s = fmtICS(start); const en = fmtICS(end);
  const ics = `BEGIN:VCALENDAR\nVERSION:2.0\nBEGIN:VEVENT\nDTSTART:${s}\nDTEND:${en}\nSUMMARY:${title}\nLOCATION:${loc}\nDESCRIPTION:Booked via signpost\nEND:VEVENT\nEND:VCALENDAR`;
  const blob = new Blob([ics], {type:'text/calendar'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'signpost-booking.ics';
  a.click();
}

