function simulatePlay(el) {
  el.textContent = '⏸';
  const fill = document.getElementById('progress-fill');
  if (!fill) return;
  let w = 0;
  const t = setInterval(() => { w += 0.5; fill.style.width = w + '%'; if (w >= 100) clearInterval(t); }, 70);
}

