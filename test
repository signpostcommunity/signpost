// ===== FILTER REQUESTS: actually show/hide cards =====
(function() {
  window.filterReqs = function(btn, filter) {
    btn.closest('div').querySelectorAll('.recur-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const panel = btn.closest('.dash-panel');
    if (!panel) return;
    panel.querySelectorAll('.request-card').forEach(card => {
      if (filter === 'all') { card.style.display = ''; return; }
      const badge = card.querySelector('.request-status');
      if (!badge) { card.style.display = ''; return; }
      const text = badge.textContent.toLowerCase();
      const statusMap = {
        pending: ['pending','awaiting'],
        confirmed: ['confirmed'],
        sent: ['sent','rate sent'],
        new: ['awaiting','new'],
        responded: ['rate sent','responded'],
      };
      const matches = (statusMap[filter] || []).some(s => text.includes(s));
      card.style.display = matches ? '' : 'none';
    });
  };
})();
</script>

