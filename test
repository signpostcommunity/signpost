function buildLangPicker(containerId, top10, byContinent, otherId) {
  const container = document.getElementById(containerId);
  if (!container) return;

  let html = `<div class="lang-picker-top-label">Most Common</div>`;
  html += `<div class="chip-group" style="margin-bottom:4px;">`;
  top10.forEach(lang => {
    html += `<span class="chip" onclick="toggleChip(this)">${lang}</span>`;
  });
  html += `</div>`;

  html += `<div class="lang-picker-continents" style="margin-top:20px;">`;
  html += `<div class="lang-picker-top-label" style="margin-bottom:6px;">More Languages by Region</div>`;
  html += `<div class="continent-accordions-grid">`;

  Object.entries(byContinent).forEach(([continent, langs]) => {
    const safeId = containerId + '-' + continent.replace(/[^a-z0-9]/gi, '-');
    html += `<div class="continent-accordion" id="${safeId}">`;
    html += `<div class="continent-accordion-header" onclick="toggleContinent('${safeId}')">
      <span>${continent}</span><span class="continent-accordion-chevron">▾</span>
    </div>`;
    html += `<div class="continent-accordion-body"><div class="chip-group">`;
    langs.forEach(lang => {
      html += `<span class="chip" onclick="toggleChip(this)">${lang}</span>`;
    });
    html += `</div></div></div>`;
  });
  html += `</div></div>`; // close .continent-accordions-grid + .lang-picker-continents

  // Other chip + text field
  html += `<div style="margin-top:8px;" class="chip-group">
    <span class="chip chip-other-trigger" onclick="toggleChip(this);toggleOtherField(this,'${otherId}')">Other</span>
  </div>
  <input type="text" id="${otherId}" placeholder="Type language name…" style="display:none;margin-top:10px;">`;

  container.innerHTML = html;
}

function toggleContinent(id) {
  const el = document.getElementById(id);
  if (!el) return;
  const wasOpen = el.classList.contains('open');
  // Close all accordions in the same grid
  const grid = el.closest('.continent-accordions-grid');
  if (grid) {
    grid.querySelectorAll('.continent-accordion').forEach(a => {
      a.classList.remove('open');
      a.style.flexBasis = '';
      a.style.width = '';
    });
  }
  if (!wasOpen) {
    el.classList.add('open');
    el.style.flexBasis = '100%';
    el.style.width = '100%';
  }
}

