  });
}

function goToDashboard() {
  if (currentUserRole === 'interpreter') {
    showView('interpreter-dashboard');
  } else {
    showView('requester-dashboard');
  }
}

function handleInterpreterLogin() {
  const email = document.getElementById('login-email').value.trim();
  const password = document.getElementById('login-password').value;
  const errorEl = document.getElementById('login-error');
  if (!email || !password) {
    errorEl.style.display = 'block';
    errorEl.textContent = 'Please enter your email and password.';
    return;
  }
  // Demo: any valid-looking credentials go straight to interpreter dashboard
  errorEl.style.display = 'none';
  setUserRole('interpreter');
  showView('interpreter-dashboard');
}

function showView(view) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-' + view).classList.add('active');
  window.scrollTo(0,0);
  if (view === 'directory') renderGrid();
  if (view === 'signup') setUserRole('interpreter');
  if (view === 'requester-signup' || view === 'requester-dashboard') setUserRole('requester');
  if (view === 'interpreter-dashboard') setUserRole('interpreter');
  // Show footer on browsing views, hide on forms and dashboards
  const noFooterViews = ['signup','requester-signup','requester-dashboard','interpreter-dashboard','interpreter-portal','interpreter-login'];
  const footer = document.getElementById('site-footer');
  if (footer) footer.style.display = noFooterViews.includes(view) ? 'none' : 'flex';
