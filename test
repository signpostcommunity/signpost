  card.style.opacity = '0';
  setTimeout(() => card.remove(), 280);
}


function toggleChip(el) {
  el.classList.toggle('selected');
}

// ============ FORM STEPS ============
let currentStep = 1;
const totalSteps = 6;

function formStepChange(dir) {
  document.getElementById('form-step-'+currentStep).style.display = 'none';
  document.querySelectorAll('.form-step')[currentStep-1].classList.remove('active');
  document.querySelectorAll('.form-step')[currentStep-1].classList.add('done');

  currentStep += dir;
  currentStep = Math.max(1, Math.min(totalSteps, currentStep));

  document.getElementById('form-step-'+currentStep).style.display = 'block';
  document.querySelectorAll('.form-step').forEach((s,i) => {
    s.classList.remove('active','done');
    if (i+1 < currentStep) s.classList.add('done');
    if (i+1 === currentStep) s.classList.add('active');
  });

  document.getElementById('form-step-indicator').textContent = `Step ${currentStep} of ${totalSteps}`;
  document.getElementById('form-back-btn').style.visibility = currentStep > 1 ? 'visible' : 'hidden';
  document.getElementById('form-next-btn').textContent = currentStep === totalSteps ? 'Submit →' : 'Continue →';
  window.scrollTo(0,0);
}

